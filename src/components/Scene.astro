---
import StudyStillLife from './scenes/StudyStillLife.astro';
import VineyardDawn from './scenes/VineyardDawn.astro';
import ChateauSundown from './scenes/ChateauSundown.astro';
import SlateSlope from './scenes/SlateSlope.astro';

interface Props {
  scene: 'study-still-life' | 'vineyard-dawn' | 'chateau-sundown' | 'slate-slope';
  caption: string;
  slug?: string;
}

const { scene, caption, slug } = Astro.props;
const illustrationSlugs = new Set([
  'beibinghong',
  'cabernet-franc',
  'cabernet-gernischt',
  'cabernet-sauvignon',
  'chardonnay',
  'gewurztraminer',
  'grenache',
  'longyan',
  'malbec',
  'marselan',
  'merlot',
  'pinot-grigio',
  'pinot-noir',
  'riesling',
  'sangiovese',
  'sauvignon-blanc',
  'syrah',
  'tempranillo',
  'viognier',
  'zinfandel',
]);
const illustrationSrc = slug && illustrationSlugs.has(slug) ? `/illustrations/${slug}.svg` : undefined;
---

<div class="scene">
  {illustrationSrc ? (
    <img src={illustrationSrc} alt={caption} loading="eager" decoding="async" />
  ) : (
    <>
      {scene === 'study-still-life' && <StudyStillLife />}
      {scene === 'vineyard-dawn' && <VineyardDawn />}
      {scene === 'chateau-sundown' && <ChateauSundown />}
      {scene === 'slate-slope' && <SlateSlope />}
    </>
  )}
  <div class="scene-caption">{caption}</div>
</div>
