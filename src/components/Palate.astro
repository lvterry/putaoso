---
import { type Locale, defaultLocale } from '../i18n/ui';
import { t } from '../i18n/utils';

interface Props {
  type: 'red' | 'white' | 'rose';
  locale?: Locale;
  palate: {
    acidity: number;
    acidity_label: string;
    tannin?: number;
    tannin_label?: string;
    sweetness?: number;
    sweetness_label?: string;
    body: number;
    body_label: string;
    beginner_difficulty: number;
    beginner_difficulty_label: string;
  };
}

const { type, palate, locale = defaultLocale } = Astro.props;

const secondMetric = type === 'red'
  ? { value: palate.tannin!, label: palate.tannin_label!, dim: t(locale, 'palate.tannin') }
  : { value: palate.sweetness!, label: palate.sweetness_label!, dim: t(locale, 'palate.sweetness') };

const dots = (n: number) => Array.from({ length: 5 }, (_, i) => i < n);
---

<div class="palate">
  <div class="palate-item">
    <div class="palate-label">{t(locale, 'palate.acidity')}</div>
    <div class="palate-value">{palate.acidity_label}</div>
    <div class="palate-bar">
      {dots(palate.acidity).map((fill) => <span class={fill ? 'dot fill' : 'dot'} />)}
    </div>
  </div>
  <div class="palate-item">
    <div class="palate-label">{secondMetric.dim}</div>
    <div class="palate-value">{secondMetric.label}</div>
    <div class="palate-bar">
      {dots(secondMetric.value).map((fill) => <span class={fill ? 'dot fill' : 'dot'} />)}
    </div>
  </div>
  <div class="palate-item">
    <div class="palate-label">{t(locale, 'palate.body')}</div>
    <div class="palate-value">{palate.body_label}</div>
    <div class="palate-bar">
      {dots(palate.body).map((fill) => <span class={fill ? 'dot fill' : 'dot'} />)}
    </div>
  </div>
  <div class="palate-item">
    <div class="palate-label">{t(locale, 'palate.beginner')}</div>
    <div class="palate-value">{palate.beginner_difficulty_label}</div>
    <div class="palate-bar">
      {dots(palate.beginner_difficulty).map((fill) => <span class={fill ? 'dot fill' : 'dot'} />)}
    </div>
  </div>
</div>
