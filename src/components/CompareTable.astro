---
import type { VarietyCompareData } from '../pages/api/varieties.json';

interface Props {
  varieties: VarietyCompareData[];
}

const { varieties } = Astro.props;

/** 渲染 1–5 点状指示条 */
function dots(value: number, label: string) {
  const filled = Array.from({ length: value }, (_, i) => i);
  const empty = Array.from({ length: 5 - value }, (_, i) => i);
  return (
    <div class="compare-dots">
      <div class="compare-dots-bar">
        {filled.map(() => <span class="compare-dot fill" />)}
        {empty.map(() => <span class="compare-dot" />)}
      </div>
      <span class="compare-dots-label">{label}</span>
    </div>
  );
}
---

<div class="compare-wrapper">
  <!-- 表头 -->
  <div class="compare-header">
    <div class="compare-cell compare-dim">维度</div>
    {varieties.map((v) => (
      <div class="compare-cell compare-col-head" data-type={v.type}>
        <div class="compare-col-en">{v.name_en}</div>
        <div class="compare-col-cn">{v.name_cn}</div>
      </div>
    ))}
  </div>

  <!-- 类型 -->
  <div class="compare-row">
    <div class="compare-cell compare-dim">类型</div>
    {varieties.map((v) => (
      <div class="compare-cell compare-val">
        <span class="compare-type-badge" data-type={v.type}>
          {v.type === 'red' ? '红葡萄' : v.type === 'white' ? '白葡萄' : '桃红'}
        </span>
      </div>
    ))}
  </div>

  <!-- 原产地 -->
  <div class="compare-row">
    <div class="compare-cell compare-dim">原产地</div>
    {varieties.map((v) => (
      <div class="compare-cell compare-val">{v.origin}</div>
    ))}
  </div>

  <!-- 风味 -->
  <div class="compare-row">
    <div class="compare-cell compare-dim">风味</div>
    {varieties.map((v) => (
      <div class="compare-cell compare-val">
        <div class="compare-flavors">
          {v.flavors_professional
            .replace(/[。、，]/g, ' ')
            .split(/[、，,，\s]+/)
            .filter((f) => f.length > 0 && f.length <= 8)
            .slice(0, 5)
            .map((f) => (
              <span class="compare-flavor-tag">{f}</span>
            ))}
        </div>
      </div>
    ))}
  </div>

  <!-- 酸度 -->
  <div class="compare-row">
    <div class="compare-cell compare-dim">酸度</div>
    {varieties.map((v) => dots(v.palate.acidity, v.palate.acidity_label))}
  </div>

  <!-- 单宁 / 甜度 -->
  {(() => {
    const hasRed = varieties.some((v) => v.type === 'red');
    const hasWhite = varieties.some((v) => v.type === 'white');
    const label = hasRed && hasWhite ? '单宁 / 甜度' : hasRed ? '单宁' : '甜度';
    return (
      <div class="compare-row">
        <div class="compare-cell compare-dim">{label}</div>
        {varieties.map((v) => {
          if (v.type === 'red') {
            return dots(v.palate.tannin!, v.palate.tannin_label!);
          } else {
            return dots(v.palate.sweetness!, v.palate.sweetness_label!);
          }
        })}
      </div>
    );
  })()}

  <!-- 酒体 -->
  <div class="compare-row">
    <div class="compare-cell compare-dim">酒体</div>
    {varieties.map((v) => dots(v.palate.body, v.palate.body_label))}
  </div>

  <!-- 入门难度 -->
  <div class="compare-row">
    <div class="compare-cell compare-dim">入门难度</div>
    {varieties.map((v) => dots(v.palate.beginner_difficulty, v.palate.beginner_difficulty_label))}
  </div>

  <!-- 价格区间 -->
  <div class="compare-row">
    <div class="compare-cell compare-dim">价格区间</div>
    {varieties.map((v) => (
      <div class="compare-cell compare-val">
        <span class="compare-price">¥{v.price.min} – ¥{v.price.max}</span>
      </div>
    ))}
  </div>

  <!-- 配餐推荐 -->
  <div class="compare-row">
    <div class="compare-cell compare-dim">配餐推荐</div>
    {varieties.map((v) => (
      <div class="compare-cell compare-val">
        <ul class="compare-pairings">
          {v.pairings.slice(0, 2).map((p) => (
            <li>{p}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <!-- 标签 -->
  <div class="compare-row">
    <div class="compare-cell compare-dim">标签</div>
    {varieties.map((v) => (
      <div class="compare-cell compare-val">
        <div class="compare-tags">
          {v.flavor_tags.map((tag) => (
            <span class="compare-tag">{tag.replace(/-/g, ' ')}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>
