---
import type { SceneMotif, VarietySceneProfile } from '../data/variety-scenes';

interface Props {
  slug: string;
  profile: VarietySceneProfile;
}

const { slug, profile } = Astro.props;
const id = slug.replace(/[^a-z0-9]/g, '-');
const p = profile.palette;

const grapeLayouts = {
  tight: [
    [0, 0, 19],
    [-26, 24, 18],
    [26, 24, 18],
    [0, 48, 20],
    [-30, 70, 16],
    [28, 72, 17],
    [0, 96, 17],
    [-18, 116, 13],
    [18, 118, 13],
  ],
  loose: [
    [-10, 0, 18],
    [-44, 26, 15],
    [28, 30, 17],
    [-14, 58, 16],
    [42, 72, 14],
    [-36, 92, 13],
    [4, 112, 15],
  ],
  small: [
    [-8, 0, 14],
    [-30, 22, 13],
    [16, 24, 13],
    [-8, 46, 14],
    [-28, 66, 12],
    [18, 70, 12],
    [-4, 92, 12],
    [-18, 112, 10],
    [10, 114, 10],
  ],
  plump: [
    [0, 0, 24],
    [-34, 30, 22],
    [34, 32, 22],
    [0, 62, 24],
    [-38, 92, 20],
    [38, 96, 20],
    [0, 126, 20],
  ],
};

const motifPositions = [
  [1150, 585],
  [1255, 505],
  [1365, 600],
];

const sunOpacity = profile.time === 'night' ? 0.18 : profile.time === 'winter' ? 0.36 : 0.72;
const glassOpacity = profile.wineStyle === 'pale' ? 0.42 : profile.wineStyle === 'gold' ? 0.52 : 0.66;
const cluster = grapeLayouts[profile.grapeShape];

function motifSize(motif: SceneMotif) {
  if (motif === 'cypress' || motif === 'cedar' || motif === 'grass') return 1.25;
  if (motif === 'ice' || motif === 'flint' || motif === 'stone' || motif === 'oak') return 1.1;
  return 1;
}
---

<svg
  viewBox="0 0 1600 900"
  preserveAspectRatio="xMidYMid slice"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <defs>
    <linearGradient id={`sky-${id}`} x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color={p.skyTop} />
      <stop offset="100%" stop-color={p.skyBottom} />
    </linearGradient>
    <radialGradient id={`sun-${id}`} cx={profile.time === 'morning' ? '74%' : '70%'} cy={profile.time === 'midday' ? '26%' : '34%'} r="34%">
      <stop offset="0%" stop-color={p.accent} stop-opacity={sunOpacity} />
      <stop offset="55%" stop-color={p.accent} stop-opacity="0.22" />
      <stop offset="100%" stop-color={p.accent} stop-opacity="0" />
    </radialGradient>
    <linearGradient id={`wine-${id}`} x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color={p.wineGlow} stop-opacity="0.92" />
      <stop offset="100%" stop-color={p.wine} stop-opacity="1" />
    </linearGradient>
    <linearGradient id={`soil-${id}`} x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color={p.soil} stop-opacity="0.94" />
      <stop offset="100%" stop-color={p.ground} stop-opacity="1" />
    </linearGradient>
    <linearGradient id={`grape-${id}`} x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color={p.grapeHighlight} />
      <stop offset="100%" stop-color={p.grape} />
    </linearGradient>
    <filter id={`soft-${id}`} x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="18" />
    </filter>
  </defs>

  <rect width="1600" height="900" fill={`url(#sky-${id})`} />
  <rect width="1600" height="900" fill={`url(#sun-${id})`} />

  {profile.time === 'winter' && (
    <g fill="#f7fbff" opacity="0.48">
      <circle cx="220" cy="190" r="3" />
      <circle cx="410" cy="145" r="2" />
      <circle cx="660" cy="210" r="3" />
      <circle cx="970" cy="150" r="2" />
      <circle cx="1220" cy="220" r="3" />
      <circle cx="1420" cy="170" r="2" />
    </g>
  )}

  <path d="M 0 485 Q 260 430 520 455 T 1040 445 T 1600 425 L 1600 620 L 0 620 Z" fill={p.ground} opacity="0.42" />

  {profile.landmark === 'andes' && (
    <g opacity="0.72">
      <path d="M 0 465 L 290 260 L 445 440 L 640 250 L 840 470 L 1600 410 L 1600 560 L 0 560 Z" fill="#5f4c4b" />
      <path d="M 290 260 L 350 332 L 246 326 Z M 640 250 L 716 334 L 596 320 Z" fill="#e7d8c5" opacity="0.74" />
    </g>
  )}

  {profile.landmark === 'helan' && (
    <g opacity="0.74">
      <path d="M 0 470 Q 250 345 520 390 T 1040 376 T 1600 355 L 1600 545 L 0 560 Z" fill="#6a5d4c" />
      <path d="M 90 468 Q 420 398 680 430 T 1280 405 T 1600 396" fill="none" stroke={p.accent} stroke-width="3" opacity="0.24" />
    </g>
  )}

  {profile.landmark === 'mosel' && (
    <path d="M 0 640 C 260 590 430 690 650 640 S 1020 565 1280 630 S 1500 690 1600 650 L 1600 745 C 1320 785 1110 690 870 735 S 470 790 250 725 S 80 660 0 720 Z" fill="#748b8e" opacity="0.86" />
  )}

  {profile.composition === 'slope' && (
    <>
      <path d="M 0 505 L 1600 415 L 1600 720 L 0 720 Z" fill={`url(#soil-${id})`} opacity="0.94" />
      <g stroke={profile.time === 'winter' ? '#e9f2f7' : '#24221f'} stroke-width="2" opacity={profile.time === 'winter' ? '0.38' : '0.44'}>
        <line x1="0" y1="535" x2="1600" y2="448" />
        <line x1="0" y1="575" x2="1600" y2="488" />
        <line x1="0" y1="615" x2="1600" y2="528" />
        <line x1="0" y1="655" x2="1600" y2="568" />
      </g>
      <g fill={profile.time === 'winter' ? '#eef6fb' : p.grape} opacity={profile.time === 'winter' ? '0.86' : '0.82'}>
        <circle cx="450" cy="536" r="5" />
        <circle cx="610" cy="526" r="5" />
        <circle cx="770" cy="516" r="5" />
        <circle cx="930" cy="506" r="5" />
        <circle cx="1090" cy="496" r="5" />
        <circle cx="1250" cy="486" r="5" />
        <circle cx="1410" cy="476" r="5" />
      </g>
    </>
  )}

  {profile.composition === 'vineyard' && (
    <>
      <path d="M 0 560 L 1600 545 L 1600 760 L 0 760 Z" fill={`url(#soil-${id})`} />
      <g stroke="#181511" stroke-width="2" opacity="0.46">
        <path d="M 0 610 C 380 590 760 590 1600 580" />
        <path d="M 0 655 C 420 632 850 630 1600 618" />
        <path d="M 0 710 C 440 674 920 670 1600 650" />
      </g>
      <g fill={profile.landmark === 'old-vines' ? '#21150e' : p.grape} opacity="0.86">
        <circle cx="90" cy="625" r="6" />
        <circle cx="250" cy="620" r="6" />
        <circle cx="410" cy="615" r="6" />
        <circle cx="570" cy="610" r="6" />
        <circle cx="730" cy="605" r="6" />
        <circle cx="890" cy="600" r="6" />
        <circle cx="1050" cy="595" r="6" />
        <circle cx="1210" cy="590" r="6" />
        <circle cx="1370" cy="585" r="6" />
      </g>
      {profile.landmark === 'old-vines' && (
        <g stroke="#21150e" stroke-width="8" stroke-linecap="round" fill="none" opacity="0.9">
          <path d="M 310 625 C 300 585 330 565 320 530" />
          <path d="M 320 590 C 285 575 270 555 260 525" />
          <path d="M 320 590 C 360 570 372 550 384 520" />
        </g>
      )}
    </>
  )}

  {profile.composition === 'estate' && (
    <>
      <path d="M 0 580 L 1600 548 L 1600 760 L 0 760 Z" fill={`url(#soil-${id})`} />
      <g transform="translate(230 440)" opacity="0.9">
        {profile.landmark === 'cypress' ? (
          <>
            <rect x="95" y="66" width="155" height="86" fill="#b98a61" opacity="0.82" />
            <polygon points="80,66 172,16 265,66" fill="#7f3f2d" />
            <path d="M 0 150 C 22 78 25 24 48 -20 C 80 38 85 92 102 150 Z" fill="#1f3124" />
            <path d="M 300 150 C 322 78 325 24 348 -20 C 380 38 385 92 402 150 Z" fill="#1f3124" />
          </>
        ) : (
          <>
            <rect x="0" y="64" width="170" height="94" fill="#b98a61" opacity="0.82" />
            <polygon points="-12,64 85,8 182,64" fill="#7f3f2d" />
            <rect x="170" y="36" width="48" height="122" fill="#a77d58" opacity="0.9" />
            <polygon points="164,36 194,-8 224,36" fill="#713726" />
            <rect x="34" y="92" width="18" height="28" fill="#321e17" opacity="0.8" />
            <rect x="78" y="92" width="18" height="28" fill="#321e17" opacity="0.8" />
            <rect x="122" y="92" width="18" height="28" fill="#321e17" opacity="0.8" />
          </>
        )}
      </g>
      {profile.landmark === 'coast' && <path d="M 0 610 C 260 585 420 625 620 602 S 930 555 1180 585 S 1460 632 1600 596" fill="none" stroke="#d7e5e7" stroke-width="5" opacity="0.32" />}
      {profile.landmark === 'plateau' && <path d="M 0 548 L 1600 536" stroke={p.accent} stroke-width="8" opacity="0.18" />}
    </>
  )}

  {profile.composition === 'still-life' && (
    <>
      <rect y="610" width="1600" height="290" fill={`url(#soil-${id})`} />
      <ellipse cx="860" cy="727" rx="260" ry="18" fill="#090605" opacity="0.28" />
      {profile.landmark === 'china-estate' && (
        <g transform="translate(220 430)" opacity="0.54">
          <rect x="0" y="80" width="170" height="70" fill="#8f744f" />
          <path d="M -15 80 Q 85 25 185 80" fill="none" stroke={p.accent} stroke-width="10" />
          <rect x="72" y="104" width="26" height="46" fill="#332419" />
        </g>
      )}
    </>
  )}

  <g transform="translate(690 352)">
    <path d="M 0 0 Q 0 165 112 192 Q 224 165 224 0 Z" fill="#f7f0e4" opacity="0.16" stroke="#fff5e8" stroke-opacity="0.36" stroke-width="2" />
    <path d="M 16 54 Q 22 162 112 184 Q 202 162 208 54 Z" fill={`url(#wine-${id})`} opacity={glassOpacity} />
    <ellipse cx="112" cy="0" rx="112" ry="15" fill="none" stroke="#fff5e8" stroke-opacity="0.44" stroke-width="2" />
    <ellipse cx="112" cy="54" rx="96" ry="12" fill={p.wineGlow} opacity="0.28" />
    <rect x="109" y="190" width="7" height="104" fill="#fff5e8" opacity="0.24" />
    <ellipse cx="112" cy="305" rx="82" ry="10" fill="#fff5e8" opacity="0.2" />
  </g>

  <g transform="translate(462 455)">
    <path d="M -18 -36 C -8 -70 28 -82 55 -58" fill="none" stroke="#394220" stroke-width="9" stroke-linecap="round" opacity="0.9" />
    <path d="M 32 -62 C 82 -75 112 -56 126 -30 C 83 -28 53 -38 32 -62 Z" fill="#445d2e" opacity="0.9" />
    {cluster.map(([cx, cy, r]) => (
      <circle cx={cx} cy={cy} r={r} fill={`url(#grape-${id})`} stroke="#1d1010" stroke-opacity="0.16" stroke-width="2" />
    ))}
    <circle cx="-9" cy="10" r="5" fill="#fff7e2" opacity="0.2" />
    <circle cx="26" cy="28" r="5" fill="#fff7e2" opacity="0.16" />
  </g>

  {profile.landmark === 'ice-vines' && (
    <g stroke="#f4fbff" stroke-width="3" stroke-linecap="round" opacity="0.62">
      <path d="M 280 650 C 300 600 285 570 320 520" />
      <path d="M 320 595 L 265 545 M 320 592 L 378 548" />
      <path d="M 1110 650 C 1134 610 1124 566 1160 520" />
      <path d="M 1160 590 L 1110 550 M 1160 590 L 1208 548" />
    </g>
  )}

  {profile.motifs.map((motif, index) => {
    const [x, y] = motifPositions[index] ?? motifPositions[0];
    const scale = motifSize(motif);
    return (
      <g transform={`translate(${x} ${y}) scale(${scale})`} opacity="0.82">
        {(motif === 'blackcurrant' || motif === 'plum' || motif === 'cherry') && (
          <>
            <circle cx="-22" cy="8" r={motif === 'cherry' ? '18' : '24'} fill={motif === 'cherry' ? '#b9333d' : p.grape} />
            <circle cx="18" cy="18" r={motif === 'cherry' ? '15' : '21'} fill={motif === 'plum' ? '#55305e' : p.grapeHighlight} />
            <path d="M -18 -10 C -8 -36 20 -40 34 -18" fill="none" stroke="#3d4c26" stroke-width="5" stroke-linecap="round" />
          </>
        )}
        {(motif === 'apple' || motif === 'pear' || motif === 'apricot' || motif === 'citrus' || motif === 'lychee') && (
          <>
            <circle cx="-10" cy="12" r="27" fill={motif === 'citrus' ? '#d7cf42' : motif === 'apricot' ? '#df9a50' : motif === 'lychee' ? '#d58b91' : '#d8c764'} />
            <path d="M -10 -15 C -2 -38 22 -38 30 -18" fill="none" stroke="#4d5a2e" stroke-width="5" stroke-linecap="round" />
            <path d="M 14 6 L 40 -8 L 30 24 Z" fill="#f6e7a4" opacity={motif === 'citrus' ? '0.85' : '0.35'} />
          </>
        )}
        {(motif === 'rose' || motif === 'flower' || motif === 'violet') && (
          <>
            <circle cx="0" cy="0" r="10" fill={motif === 'violet' ? '#7b4c91' : '#d78ca0'} />
            <circle cx="-18" cy="0" r="14" fill={motif === 'violet' ? '#5d3b76' : '#c96f89'} />
            <circle cx="18" cy="0" r="14" fill={motif === 'violet' ? '#6a4384' : '#e09aac'} />
            <circle cx="0" cy="-18" r="14" fill={motif === 'violet' ? '#8a5ca1' : '#e3a0ad'} />
            <circle cx="0" cy="18" r="14" fill={motif === 'violet' ? '#68407f' : '#c76e82'} />
          </>
        )}
        {(motif === 'grass' || motif === 'herb' || motif === 'cypress' || motif === 'cedar') && (
          <g stroke={motif === 'cedar' ? '#53351f' : '#304424'} stroke-width={motif === 'cypress' ? '8' : '5'} stroke-linecap="round" fill="none">
            <path d="M -26 36 C -18 0 -10 -22 0 -48 C 14 -15 20 8 26 36" />
            <path d="M 0 22 L -32 -10 M 0 12 L 34 -22 M 0 2 L -20 -34" opacity="0.74" />
          </g>
        )}
        {(motif === 'flint' || motif === 'stone' || motif === 'oak' || motif === 'ice' || motif === 'pepper') && (
          <>
            {motif === 'pepper' ? (
              <g fill="#171411">
                <circle cx="-20" cy="0" r="7" />
                <circle cx="4" cy="12" r="6" />
                <circle cx="26" cy="-8" r="5" />
                <circle cx="18" cy="26" r="4" />
              </g>
            ) : (
              <polygon
                points={motif === 'ice' ? '-26,26 -8,-34 30,-8 18,34' : '-34,20 -12,-26 32,-14 42,22 4,42'}
                fill={motif === 'ice' ? '#eaf7ff' : motif === 'oak' ? '#8a5a35' : '#8e8f86'}
                opacity={motif === 'ice' ? '0.8' : '0.72'}
              />
            )}
          </>
        )}
      </g>
    );
  })}

  <rect width="1600" height="900" fill="#000" opacity={profile.time === 'night' ? '0.16' : '0.04'} />
  <ellipse cx="780" cy="720" rx="560" ry="70" fill="#000" opacity="0.13" filter={`url(#soft-${id})`} />
</svg>
