---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroMap from '../components/HeroMap.astro';
import VarietyPicker from '../components/VarietyPicker.astro';

const all = await getCollection('varieties');
const varieties = all.sort((a, b) => a.data.number - b.data.number);
const liveForPicker = all
  .filter((v) => v.data.status === 'live')
  .sort((a, b) => a.data.number - b.data.number)
  .map((v) => ({
    slug: v.slug,
    name_en: v.data.name_en,
    name_cn: v.data.name_cn,
    type: v.data.type,
    number: v.data.number,
  }));

---

<BaseLayout
  title="葡萄搜・随手翻的葡萄品种图鉴"
  description="一本随手翻的葡萄品种图鉴。慢慢读，找到属于你的那一颗。"
  containerWidth="wide"
  wideFooter={true}
  hideHeader={true}
>
{/* === 编辑式封面 === */}
  <section class="cover">
    <div class="cover-bg">
      <HeroMap />
    </div>
    <div class="cover-text">
      <h1>Putaoso</h1>
      <div class="cover-subtitle">葡萄搜</div>
      <div class="cover-tagline">
        一本随手翻的葡萄品种图鉴。<br />
        慢慢读，找到属于你的那一颗。
      </div>
    </div>

  </section>

  <VarietyPicker varieties={liveForPicker} />

  {/* === 品种网格 === */}
  <section class="varieties">
    <div class="varieties-head">
      <h2>品种索引</h2>
      <button class="compare-btn" id="compare-btn" type="button">品种对比</button>
    </div>
    <div class="grid">
      {varieties.map((v) => {
        const d = v.data;
        const numStr = String(d.number).padStart(3, '0');
        const isLive = d.status === 'live';
        const typeColor = d.type === 'red' ? 'red' : d.type === 'white' ? 'white' : 'rose';
        const typeLabel = d.type === 'red' ? '红葡萄' : d.type === 'white' ? '白葡萄' : '桃红';
        const statusLabel = d.status === 'draft' ? '撰写中' : d.status === 'planned' ? '即将上线' : '';

        const inner = (
          <>
            {!isLive && <span class="stamp">即将推出</span>}
            <div>
              <div class="card-num">N° {numStr}</div>
              <div style="margin-top: 32px;">
                <svg class={`card-drop ${typeColor}`} width="10" height="14" viewBox="0 0 12 18" aria-hidden="true">
                  <path d="M6 1 C3 5 0 8.5 0 12 C0 15.3 2.7 18 6 18 C9.3 18 12 15.3 12 12 C12 8.5 9 5 6 1Z" />
                </svg>
                <span class="card-type-label">{typeLabel}</span>
              </div>
            </div>
            <div>
              <div class="card-name-en" set:html={d.name_en.replace(/ /g, '<br>')} />
              <div class="card-name-cn">{d.name_cn}</div>
              <div class="card-tagline">{d.card_tagline}</div>
              <div class="card-foot">
                <span class="card-foot-label">{isLive ? '产地' : '状态'}</span>
                <span class="card-foot-value">
                  {isLive ? d.card_origin_short : statusLabel}
                </span>
              </div>
            </div>
          </>
        );

        return isLive ? (
          <a class="card live" href={`/${v.slug}`}>{inner}</a>
        ) : (
          <div class="card upcoming">{inner}</div>
        );
      })}
    </div>
  </section>
</BaseLayout>

<script>
  document.getElementById('compare-btn')?.addEventListener('click', () => {
    window.openVarietyPicker?.();
  });
</script>
