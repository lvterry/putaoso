---
import { getCollection } from 'astro:content';
import IndexPage from '../../components/IndexPage.astro';
import { locales, defaultLocale, type Locale } from '../../i18n/ui';

export async function getStaticPaths() {
  return locales
    .filter((l) => l !== defaultLocale)
    .map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const all = await getCollection('varieties');
const varieties = all.sort((a, b) => a.data.number - b.data.number);
---

<IndexPage locale={lang as Locale} varieties={varieties} />
