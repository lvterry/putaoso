---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import VarietyPicker from '../components/VarietyPicker.astro';

const all = await getCollection('varieties');
const liveForPicker = all
  .filter((v) => v.data.status === 'live')
  .sort((a, b) => a.data.number - b.data.number)
  .map((v) => ({
    slug: v.slug,
    name_en: v.data.name_en,
    name_cn: v.data.name_cn,
    type: v.data.type,
    number: v.data.number,
  }));
---

<BaseLayout
  title="品种对比 · 葡萄搜"
  description="将不同的葡萄品种放在一起，对比它们的参数与风味差异。"
  containerWidth="wide"
>
  <VarietyPicker varieties={liveForPicker} />

  <div class="compare-page">
    <header class="compare-page-head">
      <h2>品种对比</h2>
      <button class="compare-modify-btn" id="compare-modify-btn" type="button">
        + 修改品种
      </button>
    </header>

    <!-- 对比表格容器——客户端渲染 -->
    <div id="compare-table-container">
      <div class="compare-loading">加载品种数据…</div>
    </div>

    <!-- 空状态（隐藏） -->
    <div id="compare-empty" class="compare-empty" hidden>
      <p>还没有选择品种。</p>
      <button class="compare-empty-btn" id="compare-empty-btn" type="button">
        选择品种开始对比
      </button>
    </div>
  </div>
</BaseLayout>

<script>
  (() => {
    const container = document.getElementById('compare-table-container');
    const emptyEl = document.getElementById('compare-empty');
    const modifyBtn = document.getElementById('compare-modify-btn');
    const emptyBtn = document.getElementById('compare-empty-btn');

    let ALL_VARIETIES = [];
    let ALL_SLUGS = [];

    const TAG_MAP = {
      'approachable': '易饮', 'aromatic': '芳香', 'black-fruit': '黑色水果',
      'black-pepper': '黑胡椒', 'butter': '黄油', 'cherry': '樱桃',
      'chocolate': '巧克力', 'citrus': '柑橘', 'dark-fruit': '深色水果',
      'dried-herb': '干草药', 'earth': '泥土', 'earthy': '泥土味',
      'elegant': '优雅', 'floral': '花香', 'full-body': '饱满',
      'grassy': '青草', 'herbal': '草本', 'high-acid': '高酸',
      'high-tannin': '高单宁', 'honey': '蜂蜜', 'jam': '果酱',
      'leather': '皮革', 'light': '轻盈', 'light-body': '轻盈',
      'lychee': '荔枝', 'medium-tannin': '中单宁', 'mineral': '矿物',
      'mint': '薄荷', 'mushroom': '蘑菇', 'oak': '橡木',
      'pear': '梨', 'pencil-shaving': '铅笔屑', 'plum': '李子',
      'red-fruit': '红色水果', 'rose': '玫瑰', 'round': '圆润',
      'smoked': '烟熏', 'soft-tannin': '柔顺单宁', 'spice': '香料',
      'stone-fruit': '核果', 'sweet': '甜', 'tobacco': '烟草',
      'violet': '紫罗兰', 'warm-spice': '暖香料', 'white-flower': '白花',
      'wild-berry': '野莓',
    };
    function tagLabel(t) { return TAG_MAP[t] || t.replace(/-/g, ' '); }

    // ===== 工具函数 =====
    function parseHash() {
      const raw = location.hash.replace(/^#/, '').trim();
      if (!raw) return [];
      return raw.split(',').map((s) => s.trim()).filter(Boolean);
    }

    function esc(s) {
      const div = document.createElement('div');
      div.textContent = s;
      return div.innerHTML;
    }

    function dotsHtml(value, label) {
      let d = '<div class="compare-dots"><div class="compare-dots-bar">';
      for (let i = 0; i < 5; i++) {
        d += `<span class="compare-dot${i < value ? ' fill' : ''}"></span>`;
      }
      d += `</div><span class="compare-dots-label">${esc(label)}</span></div>`;
      return d;
    }

    // ===== 提取风味关键词 =====
    function extractFlavors(text) {
      return text
        .replace(/[。、，（）\(\)]/g, ' ')
        .split(/[、，,，\s]+/)
        .filter((f) => f.length > 0 && f.length <= 8)
        .slice(0, 5);
    }

    // ===== 构建一个品种的维度列表（用于移动端卡片） =====
    function varietyFields(v) {
      const dims = [];
      dims.push(['类型', `<span class="compare-type-badge" data-type="${v.type}">${v.type === 'red' ? '红葡萄' : v.type === 'white' ? '白葡萄' : '桃红'}</span>`]);
      dims.push(['原产地', esc(v.origin)]);
      dims.push(['风味', `<div class="compare-flavors">${extractFlavors(v.flavors_professional).map((f) => `<span class="compare-flavor-tag">${esc(f)}</span>`).join('')}</div>`]);
      dims.push(['酸度', dotsHtml(v.palate.acidity, v.palate.acidity_label)]);

      let secondDim, secondVal;
      if (v.type === 'red') {
        secondDim = '单宁';
        secondVal = dotsHtml(v.palate.tannin, v.palate.tannin_label);
      } else {
        secondDim = '甜度';
        secondVal = dotsHtml(v.palate.sweetness, v.palate.sweetness_label);
      }
      dims.push([secondDim, secondVal]);
      dims.push(['酒体', dotsHtml(v.palate.body, v.palate.body_label)]);
      dims.push(['入门难度', dotsHtml(v.palate.beginner_difficulty, v.palate.beginner_difficulty_label)]);
      dims.push(['价格区间', `<span class="compare-price">¥${v.price.min} – ¥${v.price.max}</span>`]);
      dims.push(['配餐推荐', `<ul class="compare-pairings">${v.pairings.slice(0, 2).map((p) => `<li>${esc(p)}</li>`).join('')}</ul>`]);
      dims.push(['标签', `<div class="compare-tags">${v.flavor_tags.map((t) => `<span class="compare-tag">${esc(tagLabel(t))}</span>`).join('')}</div>`]);
      return dims;
    }

    // ===== 渲染 =====
    function render() {
      const slugs = parseHash();
      const validSet = new Set(ALL_SLUGS);
      const selected = slugs
        .filter((s) => validSet.has(s))
        .filter((s, i, arr) => arr.indexOf(s) === i);

      if (selected.length === 0) {
        container.innerHTML = '';
        container.hidden = true;
        emptyEl.hidden = false;
        return;
      }

      const slugOrder = new Map(ALL_VARIETIES.map((v) => [v.slug, v.number]));
      selected.sort((a, b) => (slugOrder.get(a) ?? 999) - (slugOrder.get(b) ?? 999));
      const sel = ALL_VARIETIES.filter((v) => selected.includes(v.slug));
      const n = sel.length;

      // ---- 桌面端：网格表格 ----
      let html = '<div class="compare-desktop">';
      html += '<div class="compare-wrapper">';

      const grid = (inside) => inside.map((cell) => `<td class="compare-cell compare-val">${cell}</td>`).join('');

      // 表头
      html += `<table class="compare-table"><thead><tr><th class="compare-cell compare-dim"></th>`;
      for (const v of sel) {
        html += `<th class="compare-cell compare-col-head" data-type="${v.type}"><div class="compare-col-en">${esc(v.name_en)}</div><div class="compare-col-cn">${esc(v.name_cn)}</div></th>`;
      }
      html += '</tr></thead><tbody>';

      // 类型
      html += `<tr><td class="compare-cell compare-dim">类型</td>${grid(sel.map((v) => {
        const label = v.type === 'red' ? '红葡萄' : v.type === 'white' ? '白葡萄' : '桃红';
        return `<span class="compare-type-badge" data-type="${v.type}">${label}</span>`;
      }))}</tr>`;

      // 原产地
      html += `<tr><td class="compare-cell compare-dim">原产地</td>${grid(sel.map((v) => esc(v.origin)))}</tr>`;

      // 风味
      html += `<tr><td class="compare-cell compare-dim">风味</td>${grid(sel.map((v) => {
        const flavors = extractFlavors(v.flavors_professional).map((f) => `<span class="compare-flavor-tag">${esc(f)}</span>`).join('');
        return `<div class="compare-flavors">${flavors}</div>`;
      }))}</tr>`;

      // 酸度
      html += `<tr><td class="compare-cell compare-dim">酸度</td>${grid(sel.map((v) => dotsHtml(v.palate.acidity, v.palate.acidity_label)))}</tr>`;

      // 单宁/甜度
      const hasRed = sel.some((v) => v.type === 'red');
      const hasWhite = sel.some((v) => v.type === 'white');
      const tanninDim = hasRed && hasWhite ? '单宁 / 甜度' : hasRed ? '单宁' : '甜度';
      html += `<tr><td class="compare-cell compare-dim">${tanninDim}</td>${grid(sel.map((v) => {
        if (v.type === 'red') return dotsHtml(v.palate.tannin, v.palate.tannin_label);
        return dotsHtml(v.palate.sweetness, v.palate.sweetness_label);
      }))}</tr>`;

      // 酒体
      html += `<tr><td class="compare-cell compare-dim">酒体</td>${grid(sel.map((v) => dotsHtml(v.palate.body, v.palate.body_label)))}</tr>`;

      // 入门难度
      html += `<tr><td class="compare-cell compare-dim">入门难度</td>${grid(sel.map((v) => dotsHtml(v.palate.beginner_difficulty, v.palate.beginner_difficulty_label)))}</tr>`;

      // 价格区间
      html += `<tr><td class="compare-cell compare-dim">价格区间</td>${grid(sel.map((v) => `<span class="compare-price">¥${v.price.min} – ¥${v.price.max}</span>`))}</tr>`;

      // 配餐推荐
      html += `<tr><td class="compare-cell compare-dim">配餐推荐</td>${grid(sel.map((v) => {
        const items = v.pairings.slice(0, 2).map((p) => `<li>${esc(p)}</li>`).join('');
        return `<ul class="compare-pairings">${items}</ul>`;
      }))}</tr>`;

      // 标签
      html += `<tr><td class="compare-cell compare-dim">标签</td>${grid(sel.map((v) => {
        const tags = v.flavor_tags.map((t) => `<span class="compare-tag">${esc(tagLabel(t))}</span>`).join('');
        return `<div class="compare-tags">${tags}</div>`;
      }))}</tr>`;

      html += '</tbody></table></div></div>';

      // ---- 移动端：每个品种一张卡片 ----
      html += '<div class="compare-mobile">';
      for (const v of sel) {
        html += `<div class="compare-card" data-type="${v.type}">`;
        html += `<div class="compare-card-head"><div class="compare-col-en">${esc(v.name_en)}</div><div class="compare-col-cn">${esc(v.name_cn)}</div></div>`;
        html += '<div class="compare-card-body">';
        for (const [dim, val] of varietyFields(v)) {
          html += `<div class="compare-card-row"><div class="compare-card-dim">${dim}</div><div class="compare-card-val">${val}</div></div>`;
        }
        html += '</div></div>';
      }
      html += '</div>';

      container.innerHTML = html;
      container.hidden = false;
      emptyEl.hidden = true;
    }

    function openPicker() {
      const current = parseHash();
      window.openVarietyPicker?.(current.length > 0 ? current : undefined);
    }

    async function init() {
      try {
        const res = await fetch('/api/varieties.json');
        ALL_VARIETIES = await res.json();
        ALL_SLUGS = ALL_VARIETIES.map((v) => v.slug);
        render();
      } catch (e) {
        container.innerHTML = '<div class="compare-loading" style="color: var(--wine);">数据加载失败，请刷新重试</div>';
      }
    }

    window.addEventListener('hashchange', render);
    modifyBtn?.addEventListener('click', openPicker);
    emptyBtn?.addEventListener('click', openPicker);

    init();
  })();
</script>

<style is:global>
  .compare-page {
    padding-top: 48px;
  }
  .compare-page-head {
    display: flex; align-items: baseline; gap: 16px;
    margin-bottom: 40px; flex-wrap: wrap;
  }
  .compare-page-head h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px; font-weight: 500; margin: 0; letter-spacing: 0.3px;
  }
  .compare-modify-btn {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px; letter-spacing: 1px; text-transform: uppercase;
    background: none; border: 1px solid var(--rule); color: var(--ink-faded);
    padding: 4px 12px; border-radius: 4px; cursor: pointer;
    transition: border-color 0.15s, color 0.15s; margin-left: auto;
  }
  .compare-modify-btn:hover { border-color: var(--wine); color: var(--wine); }

  .compare-empty {
    text-align: center; padding: 80px 24px;
  }
  .compare-empty p {
    font-family: 'Cormorant Garamond', serif; font-size: 20px;
    color: var(--ink-faded); margin: 0 0 16px;
  }
  .compare-empty-btn {
    font-family: 'JetBrains Mono', monospace; font-size: 11px;
    letter-spacing: 1px; text-transform: uppercase;
    background: var(--wine); color: var(--paper); border: none;
    padding: 8px 20px; border-radius: 4px; cursor: pointer;
  }
  .compare-empty-btn:hover { opacity: 0.85; }
  .compare-loading {
    text-align: center; padding: 60px; color: var(--ink-faded);
    font-family: 'Cormorant Garamond', serif; font-size: 18px;
  }

  /* ===== 桌面表格 ===== */
  .compare-desktop { display: none; }
  @media (min-width: 769px) { .compare-desktop { display: block; } }

  .compare-wrapper {
    border: 1px solid var(--rule); border-radius: 8px; overflow: hidden;
  }
  .compare-table {
    width: 100%; border-collapse: collapse;
  }
  .compare-table th, .compare-table td {
    padding: 14px 16px; min-width: 0;
    border-bottom: 1px solid var(--rule);
  }
  .compare-table .compare-dim {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 1px; text-transform: uppercase;
    color: var(--ink-faded); border-right: 1px solid var(--rule);
    background: color-mix(in srgb, var(--wine) 3%, var(--paper));
    width: 100px; white-space: nowrap;
  }
  .compare-col-head {
    text-align: center; padding: 20px 16px !important;
    border-bottom: 2px solid var(--rule) !important;
  }
  .compare-col-en {
    font-family: 'Cormorant Garamond', serif; font-size: 18px;
    font-weight: 500; line-height: 1.2;
  }
  .compare-col-cn {
    font-family: 'Noto Serif SC', serif; font-size: 13px;
    color: var(--ink-faded); margin-top: 2px;
  }
  .compare-val {
    text-align: center; vertical-align: middle;
    font-family: 'Noto Serif SC', serif; font-size: 14px;
    color: var(--ink-soft); line-height: 1.5;
  }

  /* 类型 badge */
  .compare-type-badge {
    font-family: 'JetBrains Mono', monospace; font-size: 10px;
    letter-spacing: 1px; padding: 2px 8px; border-radius: 3px;
    text-transform: uppercase;
  }
  .compare-type-badge[data-type='red'] {
    color: var(--wine); background: color-mix(in srgb, var(--wine) 12%, transparent);
  }
  .compare-type-badge[data-type='white'] {
    color: var(--ink-soft); background: color-mix(in srgb, var(--ink-soft) 10%, transparent);
  }
  .compare-type-badge[data-type='rose'] {
    color: var(--highlight); background: color-mix(in srgb, var(--highlight) 12%, transparent);
  }

  /* 风味标签 */
  .compare-flavors {
    display: flex; flex-wrap: wrap; gap: 4px; justify-content: center;
  }
  .compare-flavor-tag {
    font-family: 'Noto Serif SC', serif; font-size: 12px; padding: 2px 6px;
    background: color-mix(in srgb, var(--ink) 6%, transparent);
    border-radius: 3px; white-space: nowrap;
  }

  /* 点状条 */
  .compare-dots {
    display: flex; flex-direction: column; align-items: center; gap: 4px;
  }
  .compare-dots-bar { display: flex; gap: 4px; }
  .compare-dot {
    width: 10px; height: 10px; border-radius: 50%; background: var(--rule);
  }
  .compare-dot.fill { background: var(--wine); }
  .compare-dots-label {
    font-family: 'Noto Serif SC', serif; font-size: 11px; color: var(--ink-faded);
  }

  /* 价格 */
  .compare-price {
    font-family: 'JetBrains Mono', monospace; font-size: 14px; color: var(--ink-soft);
  }

  /* 配餐 */
  .compare-pairings {
    list-style: none; padding: 0; margin: 0;
    text-align: left; font-size: 13px;
  }
  .compare-pairings li { position: relative; padding-left: 14px; }
  .compare-pairings li::before {
    content: '—'; position: absolute; left: 0; color: var(--ink-faded);
  }

  /* 标签云 */
  .compare-tags {
    display: flex; flex-wrap: wrap; gap: 4px; justify-content: center;
  }
  .compare-tag {
    font-family: 'JetBrains Mono', monospace; font-size: 9px;
    letter-spacing: 0.5px; text-transform: uppercase;
    padding: 2px 6px; border: 1px solid var(--rule);
    border-radius: 3px; color: var(--ink-faded);
  }

  /* ===== 移动端：每个品种一张卡片 ===== */
  .compare-mobile { display: none; }
  @media (max-width: 768px) { .compare-mobile { display: block; } }

  .compare-card {
    border: 1px solid var(--rule); border-radius: 8px;
    margin-bottom: 24px; overflow: hidden;
  }
  .compare-card-head {
    text-align: center; padding: 20px 16px 14px;
    border-bottom: 2px solid var(--rule);
  }
  .compare-card-head .compare-col-en {
    font-family: 'Cormorant Garamond', serif; font-size: 22px;
    font-weight: 500; line-height: 1.2;
  }
  .compare-card-head .compare-col-cn {
    font-family: 'Noto Serif SC', serif; font-size: 14px;
    color: var(--ink-faded); margin-top: 2px;
  }
  .compare-card-body {
    display: grid; grid-template-columns: auto 1fr;
  }
  .compare-card-row {
    display: contents;
  }
  .compare-card-dim {
    font-family: 'JetBrains Mono', monospace; font-size: 9px;
    letter-spacing: 1px; text-transform: uppercase;
    color: var(--ink-faded);
    background: color-mix(in srgb, var(--wine) 3%, var(--paper));
    padding: 10px 14px; border-bottom: 1px solid var(--rule);
    display: flex; align-items: center;
  }
  .compare-card-val {
    padding: 10px 14px; border-bottom: 1px solid var(--rule);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Noto Serif SC', serif; font-size: 14px;
    color: var(--ink-soft); text-align: center;
  }
  .compare-card-row:last-of-type .compare-card-dim,
  .compare-card-row:last-of-type .compare-card-val {
    border-bottom: none;
  }
</style>
