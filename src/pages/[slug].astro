---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Scene from '../components/Scene.astro';
import Palate from '../components/Palate.astro';
import ShareCard from '../components/ShareCard.astro';

export async function getStaticPaths() {
  const all = await getCollection('varieties');
  // 只为已上线的品种生成路由
  const live = all.filter((v) => v.data.status === 'live');
  return live.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry, all },
  }));
}

interface Props {
  entry: CollectionEntry<'varieties'>;
  all: CollectionEntry<'varieties'>[];
}

const { entry, all } = Astro.props;
const data = entry.data;

const typeLabel = data.type === 'red' ? 'Red' : data.type === 'white' ? 'White' : 'Rosé';
const numberStr = String(data.number).padStart(3, '0');

const regionBadgeLabels: Record<string, string> = {
  'The Heartland': '核心产区',
  'The Origin': '发源地',
  'The New World': '新世界',
  'The Accessible': '亲民入门',
  'The Classic': '经典产区',
  'The Powerful': '强劲风格',
  'The Portuguese Side': '葡萄牙一侧',
  'The Crisp Style': '清爽风格',
  'The Rich Style': '丰腴风格',
  'The Old World': '旧世界',
  'The Mineral': '矿物风格',
  'The Capital Side': '京城周边',
  'The Coastal Edge': '海岸边缘',
  'The China Flagship': '中国标杆',
  'The Frontier': '前沿产区',
  'The Coastal Voice': '海岸表达',
  'The Intense': '浓郁风格',
  'The Hidden Gem': '隐藏宝藏',
  'The Holy Land': '圣地',
  'Across the Rhine': '莱茵河对岸',
  'The Grand': '顶级表达',
  'The Altitude': '高海拔',
  'The New Burgundy': '新勃艮第',
  'The Southernmost': '南境产区',
  'The Pure Expression': '纯粹表达',
  'The Blend Partner': '混酿搭档',
  'The Italian Voice': '意式表达',
  'The Super-Tuscan': '超级托斯卡纳',
  'The Value': '性价比之选',
  'The Ice Wine Heartland': '冰酒核心',
  'The Western Trial': '西部尝试',
  'The Northern Reach': '北方延伸',
  'The Western Reach': '西部延伸',
  'The Blend': '混酿风格',
  'The Bold': '豪放风格',
  'The Old Country': '旧大陆故乡',
};

// 把相似品种的 slug 查一下：如果对方已上线，给链接；否则纯文本
const liveSlugs = new Set(all.filter((v) => v.data.status === 'live').map((v) => v.slug));

// 把价格 caveat / pairing intro / region body / avoid 等里可能有 markdown 加粗的字符串处理一下
// 简单的 **xxx** → <strong>xxx</strong>
function md(s: string) {
  return s.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
}
---

<BaseLayout
  title={`${data.name_cn} ${data.name_en} — 葡萄搜`}
  description={data.hero_quote}
  navMeta={`N° ${numberStr}`}
>
  <header class="hero">
    <h1 set:html={data.name_en.replace(/ /g, '<br>')} />
    <div class="hero-cn">{data.name_cn}</div>
    {data.aliases && data.aliases.length > 0 && (
      <div class="hero-alias">别名 · {data.aliases.join(' · ')}</div>
    )}
    <div class="hero-quote">{data.hero_quote}</div>
    <ShareCard
      slug={entry.slug}
      number={data.number}
      name_en={data.name_en}
      name_cn={data.name_cn}
      type={data.type}
      origin={data.origin}
      hero_quote={data.hero_quote}
      hero_scene={data.hero_scene}
      flavors_professional={data.flavors_professional}
      flavor_tags={data.flavor_tags}
    />
  </header>

  <Scene slug={entry.slug} scene={data.hero_scene} caption={data.hero_scene_caption} />

  {/* === 身份 === */}
  <section>
    <div class="section-label">Identity</div>
    <h2>它是谁</h2>
    <dl class="facts">
      <dt>类型</dt>
      <dd>{typeLabel === 'Red' ? '红葡萄' : typeLabel === 'White' ? '白葡萄' : '桃红'}</dd>

      <dt>原产地</dt>
      <dd>{data.origin}</dd>

      {data.parents && (
        <>
          <dt>亲本</dt>
          <dd>
            {data.parents.p1 && data.parents.p2 ? (
              <>{data.parents.p1} × {data.parents.p2}</>
            ) : null}
            {data.parents.note && (
              <span class="note">{data.parents.p1 ? ' · ' : ''}{data.parents.note}</span>
            )}
          </dd>
        </>
      )}

      <dt>葡萄科</dt>
      <dd>欧亚种葡萄 Vitis vinifera</dd>
    </dl>
  </section>

  {/* === 喝起来什么样 === */}
  <section>
    <div class="section-label">Tasting Notes</div>
    <h2>喝起来什么样</h2>

    <div class="flavor-pro">
      {data.flavors_professional}
    </div>

    {/* 风味人话版 */}
    <div class="prose">
      {data.flavors_casual.map((p) => (
        <p set:html={md(p)} />
      ))}
    </div>

    <Palate type={data.type} palate={data.palate} />
  </section>

  {/* === 价格 === */}
  <section>
    <div class="section-label">Sweet Spot</div>
    <h2>多少钱能喝到合格表现</h2>

    <div class="price-block">
      <div class="price-amount">
        <span class="currency">¥</span>{data.price.min}<span class="dash"> – </span>{data.price.max}
      </div>
    </div>

    <div class="caution">
      <strong>踩雷提示</strong>
      <span set:html={md(data.caveat)} />
    </div>
  </section>

  {/* === 配餐 === */}
  <section>
    <div class="section-label">Pairing</div>
    <h2>配什么吃</h2>

    <p class="pairing-intro" set:html={md(data.pairing_intro)} />

    <ol class="pairing-list">
      {data.pairings.map((dish) => <li>{dish}</li>)}
    </ol>

    <p class="avoid">{data.avoid}</p>
  </section>

  {/* === 产区 === */}
  <section>
    <div class="section-label">Terroir</div>
    <h2>三个代表产区</h2>

    <div class="cards">
      {data.regions.map((r) => (
        <div class="card region-card">
          <div>
            <div class="card-title">
              {r.name_cn}
              <span class="en">{r.name_en}</span>
            </div>
            <div class="card-meta">{regionBadgeLabels[r.badge] ?? r.badge}</div>
          </div>
          <div class="card-body">{r.body}</div>
        </div>
      ))}
    </div>
  </section>

  {/* === 酒款 === */}
  <section>
    <div class="section-label">Bottles to Try</div>
    <h2>三款值得一试</h2>

    <div class="cards">
      {data.bottles.map((b) => (
        <div class="card">
          <div>
            <div class="card-title">
              {b.name_en}
              <span class="cn">{b.name_cn}</span>
            </div>
            <div class="card-meta">
              <span class="price">≈ ¥{b.price.toLocaleString()}</span>
            </div>
          </div>
          <div class="card-body">{b.body}</div>
        </div>
      ))}
    </div>
  </section>

  {/* === 类似品种 === */}
  <section>
    <div class="section-label">If You Like This</div>
    <h2>喜欢{data.name_cn}，还可以试试</h2>

    <div class="similar">
      {data.similar.map((s) => (
        <div class="similar-item">
          {liveSlugs.has(s.slug) ? (
            <a class="similar-name" href={`/${s.slug}`}>
              {s.name_en}
              <span class="cn">{s.name_cn}</span>
            </a>
          ) : (
            <div class="similar-name">
              {s.name_en}
              <span class="cn">{s.name_cn}</span>
            </div>
          )}
          <div class="similar-desc">{s.body}</div>
        </div>
      ))}
    </div>
  </section>

  {/* === 关于这个品种 === */}
  <section>
    <div class="section-label">A Brief History</div>
    <h2>关于这个品种</h2>

    <div class="prose">
      {data.history.map((p) => (
        <p set:html={md(p)} />
      ))}
    </div>
  </section>

</BaseLayout>
