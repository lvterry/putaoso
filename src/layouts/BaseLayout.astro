---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  containerWidth?: 'narrow' | 'wide';
  navMeta?: string;
  wideFooter?: boolean;
  hideHeader?: boolean;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  robots?: string;
}

const {
  title,
  description = '一本随手翻的葡萄品种图鉴',
  containerWidth = 'narrow',
  navMeta = '',
  wideFooter = false,
  hideHeader = false,
  structuredData = [],
  robots = 'index, follow',
} = Astro.props;

const containerClass = containerWidth === 'wide' ? 'container wide' : 'container';
const footerClass = wideFooter ? 'site wide' : 'site';
const siteOrigin = Astro.site ? Astro.site.origin : 'https://putaoso.com';
const canonicalPath = Astro.url?.pathname ?? '/';
const canonicalUrl = `${siteOrigin}${canonicalPath}`;
const socialImagePath = '/og-image.svg';
const socialImageUrl = `${siteOrigin}${socialImagePath}`;
const baseStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Putaoso',
  alternateName: '葡萄搜',
  url: siteOrigin,
  description: '一本随手翻的葡萄品种图鉴',
  inLanguage: 'zh-CN',
};
const pageStructuredData = Array.isArray(structuredData) ? structuredData : [structuredData];
const structuredDataJson = JSON.stringify([baseStructuredData, ...pageStructuredData]).replace(
  /</g,
  '\\u003c',
);
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="light dark" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={robots} />
  <link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png" />
  <link rel="icon" href="/favicon-16x16.png" sizes="16x16" type="image/png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#9f42f4" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" title="葡萄搜 · 葡萄品种图鉴" href="/rss.xml" />
  <link rel="api-catalog" type="application/linkset+json" href="/.well-known/api-catalog" />
  <link rel="author" href="/humans.txt" />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:site_name" content="Putaoso" />
  <meta property="og:type" content={canonicalPath === '/' ? 'website' : 'article'} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={socialImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="zh_CN" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={socialImageUrl} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400;1,500&family=Noto+Serif+SC:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400&display=swap"
    rel="stylesheet"
  />
  <script type="application/ld+json" set:html={structuredDataJson} />
</head>
<body>
  <a class="skip-link" href="#main">跳到主要内容</a>
  <div class={containerClass}>
    {!hideHeader && (
      <nav class="top">
        <a class="logo" href="/" aria-label="Putaoso 葡萄搜">
          <img class="logo-mark" src="/logo.png" alt="" width="44" height="44" />
          <span class="logo-wordmark"><span lang="en">Putaoso</span><span>葡萄搜</span></span>
        </a>
        <slot name="nav-middle" />
        {navMeta && <div class="nav-meta">{navMeta}</div>}
      </nav>
    )}

    <main id="main" tabindex="-1">
      <slot />
    </main>

    <footer class={footerClass}>
      {wideFooter ? (
        <>
          <div class="footer-mark"><img src="/logo.png" alt="" width="52" height="52" /><span lang="en">Putaoso</span><span>葡萄搜</span></div>
          <div class="footer-tag"><span lang="en">A field guide to wine grapes</span><br />慢慢读，找到属于你的那一颗</div>
          <div class="footer-meta">
            © 2026 · putaoso.com<br />
            <a href="/privacy">Privacy</a> · <a href="/llms.txt">llms.txt</a> · <a href="/rss.xml">RSS</a>
          </div>
        </>
      ) : (
        <>
          <div class="footer-mark"><img src="/logo.png" alt="" width="52" height="52" /><span lang="en">Putaoso</span><span>葡萄搜</span></div>
          <div class="footer-meta footer-meta-spaced">
            <span lang="en">A field guide to wine grapes</span> · 2026<br />
            <a href="/privacy">Privacy</a> · <a href="/llms.txt">llms.txt</a> · <a href="/rss.xml">RSS</a>
          </div>
        </>
      )}
    </footer>
  </div>
  <script is:inline>
    (() => {
      if (navigator.globalPrivacyControl) return;

      const script = document.createElement('script');
      script.defer = true;
      script.src = 'https://analytics.putaoso.com/script.js';
      script.dataset.websiteId = 'a425a6b0-a352-4cfc-b1fb-9b7451b83970';
      document.head.appendChild(script);
    })();
  </script>
</body>
</html>
