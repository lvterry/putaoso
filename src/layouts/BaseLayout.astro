---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  containerWidth?: 'narrow' | 'wide';
  navMeta?: string;
  wideFooter?: boolean;
  hideHeader?: boolean;
}

const {
  title,
  description = '一本随手翻的葡萄品种图鉴',
  containerWidth = 'narrow',
  navMeta = '',
  wideFooter = false,
  hideHeader = false,
} = Astro.props;

const containerClass = containerWidth === 'wide' ? 'container wide' : 'container';
const footerClass = wideFooter ? 'site wide' : 'site';
const siteOrigin = Astro.site ? Astro.site.origin : '';
const canonicalPath = Astro.url?.pathname ?? '/';
const canonicalUrl = siteOrigin ? `${siteOrigin}${canonicalPath}` : canonicalPath;
const socialImagePath = '/og-image.svg';
const socialImageUrl = siteOrigin ? `${siteOrigin}${socialImagePath}` : socialImagePath;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png" />
  <link rel="icon" href="/favicon-16x16.png" sizes="16x16" type="image/png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#c9b3ae" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  {siteOrigin && <link rel="canonical" href={canonicalUrl} />}
  <meta property="og:site_name" content="Putaoso" />
  <meta property="og:type" content={canonicalPath === '/' ? 'website' : 'article'} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={socialImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="zh_CN" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={socialImageUrl} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400;1,500&family=Noto+Serif+SC:wght@300;400;500;600;700&family=JetBrains+Mono:wght@300;400&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <div class={containerClass}>
    {!hideHeader && (
      <nav class="top">
        <a class="logo" href="/">Putaoso<span>葡萄搜</span></a>
        <slot name="nav-middle" />
        {navMeta && <div class="nav-meta">{navMeta}</div>}
      </nav>
    )}

    <slot />

    <footer class={footerClass}>
      {wideFooter ? (
        <>
          <div class="footer-mark">Putaoso<span>葡萄搜</span></div>
          <div class="footer-tag">A field guide to wine grapes<br />慢慢读，找到属于你的那一颗</div>
          <div class="footer-meta">© 2026 · putaoso.com</div>
        </>
      ) : (
        <>
          <div class="footer-mark">Putaoso<span>葡萄搜</span></div>
          <div class="footer-meta" style="margin-top: 16px;">A field guide to wine grapes · 2026</div>
        </>
      )}
    </footer>
  </div>
  <script defer src="https://analytics.putaoso.com/script.js" data-website-id="a425a6b0-a352-4cfc-b1fb-9b7451b83970"></script>
</body>
</html>
