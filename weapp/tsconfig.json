{
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "noImplicitReturns": true,
    "alwaysStrict": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "module": "CommonJS",
    "target": "ES2018",
    "allowJs": false,
    "removeComments": true,
    "pretty": true,
    "lib": ["ES2018"],
    "types": ["miniprogram-api-typings"]
  },
  "include": ["./miniprogram/**/*.ts"],
  "exclude": ["node_modules"]
}
