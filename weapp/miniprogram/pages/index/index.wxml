<view class="page">
  <view class="header">
    <view class="title">葡萄搜</view>
    <view class="subtitle">一本随手翻的葡萄品种图鉴 · 共 {{total}} 个品种</view>
  </view>

  <view class="map-wrap" wx:if="{{mapAvailable}}">
    <map
      class="map"
      latitude="36"
      longitude="40"
      scale="3"
      markers="{{markers}}"
      enable-zoom="{{true}}"
      enable-scroll="{{true}}"
      enable-rotate="{{false}}"
      show-compass="{{false}}"
      bindmarkertap="onMarkerTap"
      bindtap="onMapTap"
      binderror="onMapError"
    />

    <!-- 大头针 tooltip：品种简介卡片，点击进入详情 -->
    <view class="tooltip" wx:if="{{selectedRegion}}" catchtap="onNoop">
      <view class="tooltip-head">
        <text class="tooltip-region">{{selectedRegion.name_cn}}</text>
        <view class="tooltip-close" catchtap="onCloseRegion">✕</view>
      </view>
      <view
        wx:for="{{selectedRegion.varieties}}"
        wx:key="slug"
        class="tooltip-variety"
        hover-class="tooltip-variety-hover"
        data-slug="{{item.slug}}"
        data-live="{{item.live}}"
        catchtap="onRegionVarietyTap"
      >
        <view class="tooltip-names">
          <text class="tooltip-cn">{{item.name_cn}}</text>
          <text class="tooltip-en">{{item.name_en}}</text>
          <text class="tooltip-arrow">→</text>
        </view>
        <view class="tooltip-tagline">{{item.tagline}}</view>
      </view>
    </view>
  </view>

  <view class="toolbar">
    <text class="result-count">{{query ? '找到 ' + cards.length + ' 个品种' : '全部品种'}}</text>
  </view>

  <view wx:if="{{cards.length === 0}}" class="empty">
    <view class="empty-title">没有找到「{{query}}」</view>
    <view class="empty-body">试试搜中文名、英文名、别名或产地，比如 赤霞珠、Riesling、Bordeaux。</view>
  </view>

  <view class="grid">
    <view class="grid-item" wx:for="{{cards}}" wx:key="slug">
      <variety-card card="{{item}}" />
    </view>
  </view>

  <view class="footer mono">PUTAOSO · A FIELD GUIDE TO WINE GRAPES</view>
</view>

<!-- 底部固定半透明搜索入口 -->
<view class="search-bar">
  <view class="search-box">
    <text class="search-icon">⌕</text>
    <input
      class="search-input"
      type="text"
      value="{{query}}"
      placeholder="搜索品种 · 中文 / 英文 / 别名 / 产地"
      placeholder-class="search-placeholder"
      confirm-type="search"
      bindinput="onSearchInput"
    />
    <view wx:if="{{query}}" class="search-clear" bindtap="onClearSearch">✕</view>
  </view>
</view>
