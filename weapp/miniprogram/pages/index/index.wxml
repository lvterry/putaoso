<view class="page">
  <view class="header">
    <view class="title">葡萄搜</view>
    <view class="subtitle">一本随手翻的葡萄品种图鉴 · 共 {{total}} 个品种</view>
  </view>

  <view class="map-wrap" wx:if="{{mapAvailable}}">
    <map
      class="map"
      latitude="36"
      longitude="40"
      scale="3"
      markers="{{markers}}"
      enable-zoom="{{true}}"
      enable-scroll="{{true}}"
      enable-rotate="{{false}}"
      show-compass="{{false}}"
      bindmarkertap="onMarkerTap"
      bindtap="onMapTap"
      binderror="onMapError"
    />
    <view class="map-hint mono">WORLD OF GRAPES · 点击地图标记查看产区</view>
  </view>

  <view class="region-panel" wx:if="{{selectedRegion}}">
    <view class="region-head">
      <view>
        <view class="region-cn">{{selectedRegion.name_cn}}</view>
        <view class="region-en mono">{{selectedRegion.name_en}}</view>
      </view>
      <view class="region-close" bindtap="onCloseRegion">✕</view>
    </view>
    <view
      wx:for="{{selectedRegion.varieties}}"
      wx:key="slug"
      class="region-variety"
      hover-class="region-variety-hover"
      data-slug="{{item.slug}}"
      data-live="{{item.live}}"
      bindtap="onRegionVarietyTap"
    >
      <view class="region-variety-names">
        <text class="region-variety-cn">{{item.name_cn}}</text>
        <text class="region-variety-en">{{item.name_en}}</text>
        <text class="type-badge {{item.type}}">{{item.typeText}}</text>
      </view>
      <view class="region-variety-tags">
        <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="region-tag">{{tag}}</text>
        <text class="region-variety-go">查看详情 →</text>
      </view>
    </view>
  </view>

  <view class="search-wrap">
    <input
      class="search-input"
      type="text"
      value="{{query}}"
      placeholder="搜索品种 · 中文名 / 英文名 / 别名 / 产地"
      placeholder-class="search-placeholder"
      confirm-type="search"
      bindinput="onSearchInput"
    />
    <view wx:if="{{query}}" class="search-clear" bindtap="onClearSearch">✕</view>
  </view>

  <view class="toolbar">
    <text class="result-count">{{query ? '找到 ' + cards.length + ' 个品种' : '全部品种'}}</text>
    <view class="compare-link" hover-class="compare-link-hover" bindtap="onGoCompare">对比品种 →</view>
  </view>

  <view wx:if="{{cards.length === 0}}" class="empty">
    <view class="empty-title">没有找到「{{query}}」</view>
    <view class="empty-body">试试搜中文名、英文名、别名或产地，比如 赤霞珠、Riesling、Bordeaux。</view>
  </view>

  <view class="grid">
    <view class="grid-item" wx:for="{{cards}}" wx:key="slug">
      <variety-card card="{{item}}" />
    </view>
  </view>

  <view class="footer mono">PUTAOSO · A FIELD GUIDE TO WINE GRAPES</view>
</view>
