.page {
  /* 底部留出固定搜索栏的高度 */
  padding: 24rpx 32rpx calc(190rpx + env(safe-area-inset-bottom));
}

.header {
  margin: 16rpx 0 28rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 24rpx;
  color: var(--ink-faded);
  margin-top: 4rpx;
}

/* 地图贴屏幕左右两侧 */
.map-wrap {
  position: relative;
  margin: 0 -32rpx;
  border-top: 1rpx solid var(--rule);
  border-bottom: 1rpx solid var(--rule);
  background: #fff;
}

.map {
  width: 100%;
  height: 440rpx;
  display: block;
}

/* === 大头针 tooltip 卡片 === */
.tooltip {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 20rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid var(--wine);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(16, 8, 20, 0.18);
}

.tooltip-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.tooltip-region {
  font-size: 22rpx;
  color: var(--ink-faded);
  letter-spacing: 1rpx;
}

.tooltip-close {
  color: var(--ink-faded);
  font-size: 26rpx;
  padding: 4rpx 8rpx;
}

.tooltip-variety {
  padding: 12rpx 0;
}

.tooltip-variety + .tooltip-variety {
  border-top: 1rpx dashed var(--rule);
}

.tooltip-variety-hover {
  background: var(--paper-warm);
}

.tooltip-names {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.tooltip-cn {
  font-size: 30rpx;
  font-weight: 700;
}

.tooltip-en {
  font-size: 22rpx;
  color: var(--wine-deep);
}

.tooltip-arrow {
  margin-left: auto;
  color: var(--wine);
  font-size: 26rpx;
}

.tooltip-tagline {
  font-size: 24rpx;
  color: var(--ink-soft);
  line-height: 1.6;
  margin-top: 4rpx;
}

/* === 列表 === */
.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 28rpx 4rpx 20rpx;
}

.result-count {
  font-size: 24rpx;
  color: var(--ink-faded);
}

.empty {
  background: #fff;
  border: 1rpx dashed var(--rule);
  border-radius: 16rpx;
  padding: 56rpx 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.empty-body {
  font-size: 24rpx;
  color: var(--ink-faded);
  line-height: 1.7;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -10rpx;
}

.grid-item {
  width: 50%;
  padding: 10rpx;
  box-sizing: border-box;
}

.footer {
  text-align: center;
  font-size: 20rpx;
  letter-spacing: 3rpx;
  color: var(--ink-faded);
  margin-top: 56rpx;
}

/* === 底部固定半透明搜索入口 === */
.search-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, rgba(251, 247, 255, 0.92), rgba(251, 247, 255, 0));
  z-index: 10;
}

.search-box {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.78);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid var(--rule);
  border-radius: 999rpx;
  padding: 16rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(16, 8, 20, 0.1);
}

.search-icon {
  font-size: 34rpx;
  color: var(--ink-faded);
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  height: auto;
  background: transparent;
}

.search-placeholder {
  color: var(--ink-faded);
  font-size: 26rpx;
}

.search-clear {
  color: var(--ink-faded);
  font-size: 26rpx;
  padding: 8rpx;
  margin-left: 12rpx;
}
