.page {
  padding: 24rpx 32rpx 80rpx;
}

.header {
  margin: 16rpx 0 28rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 24rpx;
  color: var(--ink-faded);
  margin-top: 4rpx;
}

.map-wrap {
  border: 1rpx solid var(--rule);
  border-radius: 16rpx;
  overflow: hidden;
  background: #fff;
}

.map {
  width: 100%;
  height: 400rpx;
}

.map-hint {
  font-size: 20rpx;
  letter-spacing: 2rpx;
  color: var(--ink-faded);
  text-align: center;
  padding: 12rpx 0;
  border-top: 1rpx solid var(--rule);
}

.region-panel {
  margin-top: 20rpx;
  border: 1rpx solid var(--wine);
  border-radius: 16rpx;
  background: #fff;
  padding: 24rpx 28rpx;
}

.region-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.region-cn {
  font-size: 32rpx;
  font-weight: 700;
}

.region-en {
  font-size: 22rpx;
  color: var(--ink-faded);
  letter-spacing: 1rpx;
}

.region-close {
  color: var(--ink-faded);
  font-size: 28rpx;
  padding: 4rpx 12rpx;
}

.region-variety {
  border-top: 1rpx dashed var(--rule);
  padding: 18rpx 0;
}

.region-variety-hover {
  background: var(--paper-warm);
}

.region-variety-names {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.region-variety-cn {
  font-size: 30rpx;
  font-weight: 700;
}

.region-variety-en {
  font-size: 24rpx;
  color: var(--wine-deep);
}

.region-variety-tags {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 8rpx;
}

.region-tag {
  font-size: 20rpx;
  color: var(--ink-faded);
  background: var(--paper-warm);
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
}

.region-variety-go {
  margin-left: auto;
  font-size: 22rpx;
  color: var(--wine);
}

.search-wrap {
  position: relative;
  margin-top: 24rpx;
}

.search-input {
  background: #fff;
  border: 1rpx solid var(--rule);
  border-radius: 999rpx;
  padding: 18rpx 80rpx 18rpx 36rpx;
  font-size: 28rpx;
  height: auto;
}

.search-placeholder {
  color: var(--ink-faded);
  font-size: 26rpx;
}

.search-clear {
  position: absolute;
  right: 28rpx;
  top: 50%;
  transform: translateY(-50%);
  color: var(--ink-faded);
  font-size: 26rpx;
  padding: 8rpx;
}

.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 28rpx 4rpx 20rpx;
}

.result-count {
  font-size: 24rpx;
  color: var(--ink-faded);
}

.compare-link {
  font-size: 26rpx;
  color: var(--wine-deep);
  font-weight: 700;
}

.compare-link-hover {
  opacity: 0.7;
}

.empty {
  background: #fff;
  border: 1rpx dashed var(--rule);
  border-radius: 16rpx;
  padding: 56rpx 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.empty-body {
  font-size: 24rpx;
  color: var(--ink-faded);
  line-height: 1.7;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  margin: 0 -10rpx;
}

.grid-item {
  width: 50%;
  padding: 10rpx;
  box-sizing: border-box;
}

.footer {
  text-align: center;
  font-size: 20rpx;
  letter-spacing: 3rpx;
  color: var(--ink-faded);
  margin-top: 56rpx;
}
