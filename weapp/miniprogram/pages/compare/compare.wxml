<view class="page">
  <view class="intro">
    <view class="intro-title">选 1–4 个品种放在一起看</view>
    <view class="intro-body">类型、风味、口感、价格、配餐，一目了然。</view>
  </view>

  <variety-picker varieties="{{options}}" selected="{{selected}}" bindtoggle="onToggle" />

  <view wx:if="{{cards.length === 0}}" class="empty">
    <view class="empty-body">点上面的品种开始对比，最多同时对比 4 个。</view>
  </view>

  <view class="cards">
    <view class="compare-card" wx:for="{{cards}}" wx:key="slug">
      <view class="compare-head">
        <view>
          <view class="compare-name-cn">{{item.name_cn}}</view>
          <view class="compare-name-en">{{item.name_en}}</view>
        </view>
        <text class="type-badge {{item.type}}">{{item.typeText}}</text>
      </view>

      <view class="dim">
        <view class="dim-label">原产地</view>
        <view class="dim-value">{{item.origin}}</view>
      </view>

      <view class="dim">
        <view class="dim-label">风味</view>
        <view class="dim-value">{{item.flavors_professional}}</view>
      </view>

      <view class="dim">
        <view class="dim-label">口感 · {{item.type === 'red' ? '含单宁' : '含甜度'}}</view>
        <palate-chart type="{{item.type}}" palate="{{item.palate}}" />
      </view>

      <view class="dim">
        <view class="dim-label">价格（合格表现）</view>
        <view class="dim-value price">{{item.priceText}}</view>
      </view>

      <view class="dim">
        <view class="dim-label">配餐</view>
        <view class="dim-value">
          <view class="pairing" wx:for="{{item.pairings}}" wx:for-item="dish" wx:key="*this">· {{dish}}</view>
        </view>
      </view>

      <view class="dim">
        <view class="dim-label">标签</view>
        <view class="tags">
          <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="tag">{{tag}}</text>
        </view>
      </view>

      <view class="go-detail" hover-class="go-detail-hover" data-slug="{{item.slug}}" bindtap="onGoDetail">
        查看 {{item.name_cn}} 详情 →
      </view>
    </view>
  </view>
</view>
