.page {
  padding: 24rpx 32rpx 80rpx;
}

.intro {
  margin: 16rpx 0 28rpx;
}

.intro-title {
  font-size: 40rpx;
  font-weight: 700;
}

.intro-body {
  font-size: 24rpx;
  color: var(--ink-faded);
  margin-top: 6rpx;
}

.empty {
  border: 1rpx dashed var(--rule);
  border-radius: 16rpx;
  padding: 64rpx 32rpx;
  text-align: center;
  margin-top: 32rpx;
}

.empty-body {
  font-size: 26rpx;
  color: var(--ink-faded);
}

.cards {
  margin-top: 32rpx;
}

.compare-card {
  background: #fff;
  border: 1rpx solid var(--rule);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 28rpx;
}

.compare-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  border-bottom: 1rpx solid var(--rule);
  padding-bottom: 20rpx;
}

.compare-name-cn {
  font-size: 40rpx;
  font-weight: 700;
}

.compare-name-en {
  font-size: 24rpx;
  color: var(--wine-deep);
}

.dim {
  margin-top: 24rpx;
}

.dim-label {
  font-size: 22rpx;
  color: var(--ink-faded);
  letter-spacing: 1rpx;
  margin-bottom: 6rpx;
}

.dim-value {
  font-size: 28rpx;
  line-height: 1.7;
}

.dim-value.price {
  font-weight: 700;
  color: var(--wine-deep);
}

.pairing {
  font-size: 26rpx;
  line-height: 1.8;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  font-size: 22rpx;
  color: var(--ink-soft);
  background: var(--paper-warm);
  border-radius: 8rpx;
  padding: 4rpx 14rpx;
}

.go-detail {
  margin-top: 32rpx;
  text-align: center;
  border: 1rpx solid var(--wine);
  color: var(--wine-deep);
  border-radius: 999rpx;
  padding: 14rpx 0;
  font-size: 26rpx;
}

.go-detail-hover {
  background: var(--paper-warm);
}
