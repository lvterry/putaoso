.picker {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  border: 1rpx solid var(--rule);
  border-radius: 999rpx;
  background: #fff;
  padding: 12rpx 24rpx;
}

.chip-hover {
  background: var(--paper-warm);
}

.chip.picked {
  background: var(--wine);
  border-color: var(--wine);
}

.chip-cn {
  font-size: 26rpx;
  color: var(--ink);
}

.chip-en {
  font-size: 20rpx;
  color: var(--ink-faded);
}

.chip.picked .chip-cn,
.chip.picked .chip-en {
  color: #fff;
}
