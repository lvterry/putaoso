<view class="picker">
  <view
    wx:for="{{chips}}"
    wx:key="slug"
    class="chip {{item.picked ? 'picked' : ''}}"
    hover-class="chip-hover"
    data-slug="{{item.slug}}"
    bindtap="onToggle"
  >
    <text class="chip-cn">{{item.name_cn}}</text>
    <text class="chip-en">{{item.name_en}}</text>
  </view>
</view>
