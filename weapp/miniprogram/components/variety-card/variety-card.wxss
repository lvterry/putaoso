.card {
  display: flex;
  flex-direction: column;
  background: #fff;
  border: 1rpx solid var(--rule);
  border-radius: 16rpx;
  padding: 28rpx;
  height: 100%;
  box-sizing: border-box;
}

.card-hover {
  background: var(--paper-warm);
}

.card-disabled {
  opacity: 0.62;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-number {
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: var(--ink-faded);
}

.card-name-cn {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
}

.card-name-en {
  font-size: 24rpx;
  color: var(--wine-deep);
  margin-bottom: 12rpx;
}

.card-tagline {
  font-size: 24rpx;
  color: var(--ink-soft);
  line-height: 1.6;
  flex: 1;
}

.card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.card-origin {
  font-size: 22rpx;
  color: var(--ink-faded);
  letter-spacing: 1rpx;
}

.card-stamp {
  font-size: 20rpx;
  color: var(--wine);
  border: 1rpx solid var(--wine);
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
  transform: rotate(-4deg);
}
