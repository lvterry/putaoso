.card {
  display: flex;
  flex-direction: column;
  background: #fff;
  border: 1rpx solid var(--rule);
  border-radius: 16rpx;
  padding: 28rpx;
  height: 100%;
  box-sizing: border-box;
}

.card-hover {
  background: var(--paper-warm);
}

.card-disabled {
  opacity: 0.62;
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 8rpx;
}

.card-name-cn {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
}

.card-tag {
  flex-shrink: 0;
  font-size: 18rpx;
  line-height: 1;
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
  border: 1rpx solid var(--rule);
  color: var(--ink-faded);
  background: var(--paper-warm);
}

.card-tag.red {
  background: #f3e3ff;
  color: #6415b8;
  border-color: #e0c2ff;
}

.card-tag.white {
  background: #fdf8e7;
  color: #8a6d1a;
  border-color: #ecdcab;
}

.card-tag.rose {
  background: #ffeef3;
  color: #b04a6c;
  border-color: #f4cdd9;
}

.card-name-en {
  font-size: 24rpx;
  color: var(--wine-deep);
  margin-bottom: 12rpx;
}

.card-tagline {
  font-size: 24rpx;
  color: var(--ink-soft);
  line-height: 1.6;
  flex: 1;
}

.card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
}

.card-origin {
  font-size: 22rpx;
  color: var(--ink-faded);
  letter-spacing: 1rpx;
}

.card-stamp {
  font-size: 20rpx;
  color: var(--wine);
  border: 1rpx solid var(--wine);
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
  transform: rotate(-4deg);
}
