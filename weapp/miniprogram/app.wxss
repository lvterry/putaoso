/* 主题变量与网站 src/styles/global.css 浅色主题保持一致 */
page {
  --ink: #100814;
  --ink-soft: #2f2136;
  --ink-faded: #6b5c72;
  --paper: #fbf7ff;
  --paper-warm: #efe4ff;
  --wine: #9f42f4;
  --wine-deep: #6415b8;
  --rule: #d9c6ef;
  --highlight: #18a84f;

  background: var(--paper);
  color: var(--ink);
  font-family: 'Noto Serif SC', Georgia, 'Songti SC', serif;
  font-size: 30rpx;
  line-height: 1.7;
}

.mono {
  font-family: 'Courier New', Courier, monospace;
}

.section-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--ink);
  margin: 72rpx 0 28rpx;
  line-height: 1.4;
}

.md-bold {
  font-weight: 700;
  color: var(--wine-deep);
}

.type-badge {
  display: inline-block;
  font-size: 22rpx;
  line-height: 1;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--rule);
  color: var(--ink-faded);
}

.type-badge.red {
  background: #f3e3ff;
  color: #6415b8;
  border-color: #e0c2ff;
}

.type-badge.white {
  background: #fdf8e7;
  color: #8a6d1a;
  border-color: #ecdcab;
}

.type-badge.rose {
  background: #ffeef3;
  color: #b04a6c;
  border-color: #f4cdd9;
}
