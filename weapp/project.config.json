{
  "compileType": "miniprogram",
  "miniprogramRoot": "miniprogram/",
  "appid": "touristappid",
  "projectname": "putaoso",
  "description": "葡萄搜 · 一本随手翻的葡萄品种图鉴",
  "setting": {
    "useCompilerPlugins": ["typescript"],
    "es6": true,
    "enhance": true,
    "postcss": true,
    "minified": true,
    "coverView": true,
    "urlCheck": false,
    "lazyloadPlaceholderEnable": false,
    "babelSetting": {
      "ignore": [],
      "disablePlugins": [],
      "outputPath": ""
    }
  },
  "packOptions": {
    "ignore": [
      {
        "type": "file",
        "value": "miniprogram/data/varieties.json"
      }
    ],
    "include": []
  },
  "editorSetting": {
    "tabIndent": "insertSpaces",
    "tabSize": 2
  }
}
